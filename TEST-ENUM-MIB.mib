TEST-ENUM-MIB DEFINITIONS ::= BEGIN

IMPORTS
    MODULE-IDENTITY, OBJECT-TYPE, Integer32, Unsigned32, enterprises, IpAddress, NOTIFICATION-TYPE
        FROM SNMPv2-SMI
    MODULE-COMPLIANCE, OBJECT-GROUP, NOTIFICATION-GROUP
        FROM SNMPv2-CONF
    DisplayString
        FROM SNMPv2-TC;

testEnumMIB MODULE-IDENTITY
    LAST-UPDATED "202603300000Z"
    ORGANIZATION "Test"
    CONTACT-INFO "test"
    DESCRIPTION  "MIB for testing inline enum handling with no zero value"
    REVISION     "202603300000Z"
    DESCRIPTION  "Added completion and event notification examples for trap testing"
    REVISION     "202602060000Z"
    DESCRIPTION  "Initial version"
    ::= { enterprises 99998 }

testEnumObjects OBJECT IDENTIFIER ::= { testEnumMIB 1 }

-- ============================================================
-- Scalars
-- ============================================================

testScalars OBJECT IDENTIFIER ::= { testEnumObjects 1 }

testColour OBJECT-TYPE
    SYNTAX      INTEGER {
                    red(1),
                    green(2),
                    blue(3),
                    yellow(4)
                }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "A colour with no zero value in the enumeration"
    ::= { testScalars 1 }

testPriority OBJECT-TYPE
    SYNTAX      INTEGER {
                    low(10),
                    medium(20),
                    high(30),
                    critical(50)
                }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Priority with non-contiguous values starting well above zero"
    ::= { testScalars 2 }

completionSource OBJECT-TYPE
    SYNTAX      DisplayString (SIZE (0..64))
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Source of the completion action (CLI, switch, automation, etc.)."
    ::= { testScalars 3 }

completionCode OBJECT-TYPE
    SYNTAX      Integer32 (0..2147483647)
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Equipment-defined completion code for the finished command/action."
    ::= { testScalars 4 }

eventSeverity OBJECT-TYPE
    SYNTAX      Integer32 (0..5)
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Alarm severity: 0=clear, 1=info, 2=minor, 3=major, 4=critical, 5=emergency."
    ::= { testScalars 5 }

eventText OBJECT-TYPE
    SYNTAX      DisplayString (SIZE (0..255))
    MAX-ACCESS  accessible-for-notify
    STATUS      current
    DESCRIPTION
        "Human-readable alarm/event text."
    ::= { testScalars 6 }

-- ============================================================
-- Table
-- ============================================================

testEnumTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF TestEnumEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Table for testing inline enums"
    ::= { testEnumObjects 2 }

testEnumEntry OBJECT-TYPE
    SYNTAX      TestEnumEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "An entry in the test enum table"
    INDEX       { testEnumIndex }
    ::= { testEnumTable 1 }

TestEnumEntry ::= SEQUENCE {
    testEnumIndex       Unsigned32,
    testRowColour       INTEGER,
    testRowPriority     INTEGER
}

testEnumIndex OBJECT-TYPE
    SYNTAX      Unsigned32 (1..4294967295)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Row index"
    ::= { testEnumEntry 1 }

testRowColour OBJECT-TYPE
    SYNTAX      INTEGER {
                    red(1),
                    green(2),
                    blue(3),
                    yellow(4)
                }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "A colour column with no zero value in the enumeration"
    ::= { testEnumEntry 2 }

testRowPriority OBJECT-TYPE
    SYNTAX      INTEGER {
                    low(10),
                    medium(20),
                    high(30),
                    critical(50)
                }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Priority column with non-contiguous values"
    ::= { testEnumEntry 3 }

-- ============================================================
-- EndPoint Table
-- ============================================================

-- ============================================================
-- No-Index Table (invalid by spec, used for inference testing)
-- ============================================================

testNoIndexTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF TestNoIndexEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Table with entry that omits INDEX (intentionally invalid)"
    ::= { testEnumObjects 4 }

testNoIndexEntry OBJECT-TYPE
    SYNTAX      TestNoIndexEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Entry without INDEX for inference testing"
    ::= { testNoIndexTable 1 }

TestNoIndexEntry ::= SEQUENCE {
    testNoIndexValueA   Integer32,
    testNoIndexValueB   Integer32
}

testNoIndexValueA OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Single column used as inferred index"
    ::= { testNoIndexEntry 1 }

testNoIndexValueB OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Single column used as inferred index"
    ::= { testNoIndexEntry 2 }

-- ============================================================
-- Augmented Table Pair
-- ============================================================

testAugBaseTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF TestAugBaseEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Base table used for AUGMENTS testing"
    ::= { testEnumObjects 5 }

testAugBaseEntry OBJECT-TYPE
    SYNTAX      TestAugBaseEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Base row with mixed data types"
    INDEX       { testAugBaseIndex }
    ::= { testAugBaseTable 1 }

TestAugBaseEntry ::= SEQUENCE {
    testAugBaseIndex     Unsigned32,
    testAugBase01Int       Integer32,
    testAugBase02Unsigned  Unsigned32,
    testAugBase03Name      DisplayString,
    testAugBase04Address   IpAddress,
    testAugBase05Payload   OCTET STRING
}

testAugBaseIndex OBJECT-TYPE
    SYNTAX      Unsigned32 (1..4294967295)
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Base table row index"
    ::= { testAugBaseEntry 1 }

testAugBase01Int OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Signed integer base column"
    ::= { testAugBaseEntry 2 }

testAugBase02Unsigned OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Unsigned integer base column"
    ::= { testAugBaseEntry 3 }

testAugBase03Name OBJECT-TYPE
    SYNTAX      DisplayString (SIZE (0..64))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Display string base column"
    ::= { testAugBaseEntry 4 }

testAugBase04Address OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "IP address base column"
    ::= { testAugBaseEntry 5 }

testAugBase05Payload OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE (0..64))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Octet string base column"
    ::= { testAugBaseEntry 6 }

testAugExtTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF TestAugExtEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Extension table augmenting testAugBaseEntry"
    ::= { testEnumObjects 6 }

testAugExtEntry OBJECT-TYPE
    SYNTAX      TestAugExtEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Augmenting row that extends base table rows"
    AUGMENTS    { testAugBaseEntry }
    ::= { testAugExtTable 1 }

TestAugExtEntry ::= SEQUENCE {
    testAugExt01Status      INTEGER,
    testAugExt02Counter     Integer32,
    testAugExt03Rate        Unsigned32,
    testAugExt04LastChange  Unsigned32,
    testAugExt05Owner       DisplayString,
    testAugExt06Tag         DisplayString,
    testAugExt07Address     IpAddress,
    testAugExt08Payload     OCTET STRING,
    testAugExt09Flag        INTEGER,
    testAugExt10Code        Unsigned32
}

testAugExt01Status OBJECT-TYPE
    SYNTAX      INTEGER {
                    disabled(1),
                    enabled(2),
                    testing(3)
                }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Operational status extension column"
    ::= { testAugExtEntry 1 }

testAugExt02Counter OBJECT-TYPE
    SYNTAX      Integer32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Signed counter-like extension column"
    ::= { testAugExtEntry 2 }

testAugExt03Rate OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Rate extension column"
    ::= { testAugExtEntry 3 }

testAugExt04LastChange OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Timestamp-like extension column"
    ::= { testAugExtEntry 4 }

testAugExt05Owner OBJECT-TYPE
    SYNTAX      DisplayString (SIZE (0..64))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Owner extension column"
    ::= { testAugExtEntry 5 }

testAugExt06Tag OBJECT-TYPE
    SYNTAX      DisplayString (SIZE (0..64))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Tag extension column"
    ::= { testAugExtEntry 6 }

testAugExt07Address OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Address extension column"
    ::= { testAugExtEntry 7 }

testAugExt08Payload OBJECT-TYPE
    SYNTAX      OCTET STRING (SIZE (0..128))
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Payload extension column"
    ::= { testAugExtEntry 8 }

testAugExt09Flag OBJECT-TYPE
    SYNTAX      INTEGER {
                    off(0),
                    on(1)
                }
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Boolean-like extension column"
    ::= { testAugExtEntry 9 }

testAugExt10Code OBJECT-TYPE
    SYNTAX      Unsigned32
    MAX-ACCESS  read-only
    STATUS      current
    DESCRIPTION "Code extension column"
    ::= { testAugExtEntry 10 }

endPointTable OBJECT-TYPE
    SYNTAX      SEQUENCE OF EndPointEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Table for endpoint configuration"
    ::= { testEnumObjects 3 }

endPointEntry OBJECT-TYPE
    SYNTAX      EndPointEntry
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "An entry in the endpoint table"
    INDEX       { endPointIpAddress, endPointPort }
    ::= { endPointTable 1 }

EndPointEntry ::= SEQUENCE {
    endPointIpAddress   IpAddress,
    endPointPort        Unsigned32,
    endPointName        DisplayString,
    endPointNotes       DisplayString
}

endPointIpAddress OBJECT-TYPE
    SYNTAX      IpAddress
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "IP address of the endpoint"
    ::= { endPointEntry 1 }

endPointPort OBJECT-TYPE
    SYNTAX      Unsigned32 (1..65535)
    MAX-ACCESS  not-accessible
    STATUS      current
    DESCRIPTION "Port number of the endpoint"
    ::= { endPointEntry 2 }

endPointName OBJECT-TYPE
    SYNTAX      DisplayString (SIZE (0..255))
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION "Name of the endpoint"
    ::= { endPointEntry 3 }

endPointNotes OBJECT-TYPE
    SYNTAX      DisplayString (SIZE (0..1024))
    MAX-ACCESS  read-write
    STATUS      current
    DESCRIPTION "Notes about the endpoint"
    ::= { endPointEntry 4 }

-- ============================================================
-- Notifications
-- ============================================================

testEnumNotifications OBJECT IDENTIFIER ::= { testEnumMIB 0 }

endPointStatusChange NOTIFICATION-TYPE
    OBJECTS {
        endPointIpAddress,
        endPointPort,
        endPointName,
        endPointNotes
    }
    STATUS current
    DESCRIPTION
        "Notification sent when an endpoint status changes.
         Includes both index columns (IP address and port) plus
         data columns (name and notes)."
    ::= { testEnumNotifications 1 }

completionTrap NOTIFICATION-TYPE
    OBJECTS { completionSource, completionCode }
    STATUS  current
    DESCRIPTION
        "Sent when an internal equipment command or action has completed."
    ::= { testEnumNotifications 2 }

eventTrap NOTIFICATION-TYPE
    OBJECTS { eventSeverity, eventText }
    STATUS  current
    DESCRIPTION
        "Sent for equipment events/alarms."
    ::= { testEnumNotifications 3 }

-- ============================================================
-- Conformance
-- ============================================================

testEnumConformance OBJECT IDENTIFIER ::= { testEnumMIB 2 }

testEnumGroup OBJECT-GROUP
    OBJECTS {
        testColour,
        testPriority,
        testRowColour,
        testRowPriority,
        endPointName,
        endPointNotes
    }
    STATUS  current
    DESCRIPTION "Test objects"
    ::= { testEnumConformance 1 }

testEnumNotificationGroup NOTIFICATION-GROUP
    NOTIFICATIONS {
        endPointStatusChange,
        completionTrap,
        eventTrap
    }
    STATUS  current
    DESCRIPTION "Test notifications"
    ::= { testEnumConformance 2 }

testEnumCompliance MODULE-COMPLIANCE
    STATUS  current
    DESCRIPTION "Compliance"
    MODULE
        MANDATORY-GROUPS { testEnumGroup, testEnumNotificationGroup }
    ::= { testEnumConformance 3 }

END